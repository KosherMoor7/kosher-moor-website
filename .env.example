# ─── Stripe Payment Processing ───────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
# Use pk_test_ / sk_test_ keys while testing; switch to live keys for production
STRIPE_PUBLIC_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE

# Stripe Webhook Secret — get from: https://dashboard.stripe.com/webhooks
# Run `stripe listen --forward-to localhost:3000/api/webhook` to get this locally
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ─── Anthropic AI (Claude) ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/api-keys
# Powers the Sovereign AI customer service chat and consulting assistant
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Your production domain (no trailing slash)
DOMAIN=https://thekoshermoor.com

# ─── Email (optional — for contact form submissions) ─────────────────────────
# EmailJS credentials (https://www.emailjs.com)
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
