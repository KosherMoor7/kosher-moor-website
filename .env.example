# The Kosher Moor — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ──────────────────────────────────────────────
# STRIPE — https://dashboard.stripe.com/apikeys
# ──────────────────────────────────────────────
# Publishable key (safe for client-side code)
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE

# Secret key (server-side ONLY — never expose in frontend code)
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Webhook signing secret — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Texas sales tax rate ID — https://dashboard.stripe.com/tax/rates
STRIPE_TAX_RATE_ID=txr_YOUR_TAX_RATE_ID_HERE

# ──────────────────────────────────────────────
# SITE URLS
# ──────────────────────────────────────────────
SITE_URL=https://thekoshermoor.com
STRIPE_SUCCESS_URL=https://thekoshermoor.com/?order=success
STRIPE_CANCEL_URL=https://thekoshermoor.com/?order=cancelled

# ──────────────────────────────────────────────
# EMAIL — EmailJS (client-side) or SMTP (server-side)
# ──────────────────────────────────────────────
EMAILJS_SERVICE_ID=service_YOUR_EMAILJS_SERVICE_ID
EMAILJS_TEMPLATE_ID=template_YOUR_EMAILJS_TEMPLATE_ID
EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY

# SMTP (used by server.js for server-side email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@thekoshermoor.com
SMTP_PASS=YOUR_APP_PASSWORD_HERE

# ──────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production
